{
  "name": "back-jxlivestream",
  "version": "0.2.0",
  "description": "Backend Server Jx Live Stream",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": "26.4.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "sergioortegadev",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^8.56.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
